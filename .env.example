# Wiz Cloud Security
WIZ_CLIENT_ID=
WIZ_CLIENT_SECRET=
WIZ_API_URL=https://api.us86.app.wiz.io/graphql

# PostgreSQL (vuln_db)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vuln_db
DB_USER=postgres
DB_PASS=

# Tenable Vulnerability Management
TENABLE_ACCESS_KEY=
TENABLE_SECRET_KEY=

# Tenable ASM
TENABLE_ASM_API_KEY=

# VirusTotal (virustotal-checker, ti-master-enricher)
VIRUSTOTAL_API_KEY=

# GreyNoise Community (greynoise-community, ti-master-enricher)
GREYNOISE_API_KEY=

# AlienVault OTX (alienvault-otx, ti-master-enricher)
OTX_API_KEY=

# Cisco Talos Intelligence (talos-intelligence)
TALOS_CLIENT_ID=
TALOS_CLIENT_SECRET=

# Google Chronicle SIEM (chronicle-query)
CHRONICLE_CUSTOMER_ID=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Google Chat Notifications
GOOGLE_CHAT_WEBHOOK=
